{
  "name": "@forsakringskassan/jest-config-monorepo",
  "version": "29.12.0",
  "private": true,
  "description": "Shareable jest configurations",
  "keywords": [
    "jest"
  ],
  "homepage": "https://github.com/Forsakringskassan/jest-config",
  "bugs": "https://github.com/Forsakringskassan/jest-config/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/jest-config.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "prepare": "commitlint-config",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "npm run --workspaces --if-present test"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-monorepo-config"
  },
  "dependencies": {
    "prettier-2": "npm:prettier@2.8.8"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "4.1.2",
    "@forsakringskassan/eslint-config": "15.1.9",
    "@forsakringskassan/eslint-config-cli": "15.1.1",
    "@forsakringskassan/eslint-config-jest": "15.1.12",
    "@forsakringskassan/eslint-config-typescript": "15.1.11",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "15.1.11",
    "@forsakringskassan/eslint-config-vue": "15.1.11",
    "@forsakringskassan/prettier-config": "3.7.5",
    "@html-validate/release-scripts": "7.3.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.20.0",
    "@vue/server-renderer": "3.5.39",
    "esbuild": "0.28.1",
    "lerna": "9.0.7",
    "npm-pkg-lint": "5.1.10",
    "typescript": "5.9.3",
    "vue": "3.5.39"
  },
  "engines": {
    "node": "^22.16 || >= 24",
    "npm": ">= 7"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": false,
    "nx": false,
    "unrs-resolver": true
  }
}
