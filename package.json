{
  "name": "@forsakringskassan/jest-config-monorepo",
  "version": "29.9.1",
  "private": true,
  "description": "Shareable jest configurations",
  "keywords": [
    "jest"
  ],
  "homepage": "https://github.com/Forsakringskassan/jest-config",
  "bugs": "https://github.com/Forsakringskassan/jest-config/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/jest-config.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "npm run --workspaces --if-present test"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-monorepo-config"
  },
  "dependencies": {
    "prettier-2": "npm:prettier@2.8.8"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.3.10",
    "@forsakringskassan/eslint-config": "14.1.2",
    "@forsakringskassan/eslint-config-cli": "14.1.0",
    "@forsakringskassan/eslint-config-jest": "14.1.0",
    "@forsakringskassan/eslint-config-typescript": "14.1.0",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "14.1.0",
    "@forsakringskassan/eslint-config-vue": "14.1.0",
    "@forsakringskassan/prettier-config": "3.3.6",
    "@html-validate/release-scripts": "6.10.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.37",
    "esbuild": "0.27.7",
    "lerna": "9.0.7",
    "npm-pkg-lint": "4.6.3",
    "typescript": "5.9.3",
    "vue": "3.5.31"
  },
  "engines": {
    "node": ">= 20",
    "npm": ">= 7"
  }
}
